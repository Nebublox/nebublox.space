{
    "env": {
        "browser": true,
        "es2021": true,
        "node": true
    },
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-undef": "warn",
        "no-console": "off"
    },
    "globals": {
        "firebase": "readonly",
        "grecaptcha": "readonly"
    }
}