# ===============================================
# BloxSmith AI - Environment Variables Template
# ===============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ===============================================
# SUPABASE DATABASE (Required)
# Get these from: supabase.com > Your Project > Settings > API
# ===============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Legacy naming (for backwards compatibility)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# ===============================================
# ROBLOX OAUTH (Required for Roblox Login)
# Get these from: Roblox Creator Dashboard > Open Cloud > OAuth 2.0 Apps
# ===============================================
ROBLOX_CLIENT_ID=your_client_id_here
ROBLOX_CLIENT_SECRET=your_client_secret_here

# ===============================================
# SESSION & SECURITY (Required)
# ===============================================
# Random 32+ character string for session encryption
SESSION_SECRET=generate_a_random_32_char_string_here

# ===============================================
# SITE CONFIGURATION (Required for Production)
# ===============================================
SITE_URL=https://bloxsmith.pro
